# LLM provider selected by config/llm_config.hocon
OPENAI_API_KEY=

# GitHub Projects (v2). Use a dedicated token with read:project and only the
# repository/organization read permissions this colleague needs.
GITHUB_TOKEN=
GITHUB_PROJECT_OWNER=cognizant-ai-lab
GITHUB_PROJECT_OWNER_TYPE=org
GITHUB_PROJECT_NUMBER=

# Slack bot. The channel and user allowlists are IDs, not display names.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_USER_ID=
SLACK_CHANNEL_ID=
SLACK_ALLOWED_USER_IDS=

# Optional Gmail. Generate this token explicitly with scripts/setup_gmail.py;
# the permanent server never starts an interactive OAuth flow. Read access is
# off by default. Sending additionally requires --enable-send, an exact
# recipient allowlist, and the independent live-write switch.
COLLEAGUE_GMAIL_ENABLED=false
GMAIL_TOKEN_PATH=.secrets/gmail-token.json
GMAIL_QUERY_PREFIX=in:inbox newer_than:30d
COLLEAGUE_GMAIL_WRITE_ENABLED=false
GMAIL_ALLOWED_RECIPIENTS=

# Outbound Slack is fail-closed until explicitly enabled after a dry run.
COLLEAGUE_SLACK_WRITE_ENABLED=false
# Keep mention filtering enabled unless this is a dedicated DM or bot-only channel.
COLLEAGUE_SLACK_REQUIRE_MENTION=true
COLLEAGUE_SLACK_MESSAGE_PREFIX=[neuro-san colleague]
COLLEAGUE_SLACK_DEDUPE_SECONDS=21600
# Fail without advancing the inbox checkpoint if either bound is exceeded.
COLLEAGUE_SLACK_MAX_PAGES=10
COLLEAGUE_SLACK_MAX_REQUESTS=50
COLLEAGUE_SLACK_MAX_THREAD_PAGES=10
# A new deployment ignores older ambient history instead of trying to drain the
# channel from its creation date. Socket events still remain explicitly queued.
COLLEAGUE_SLACK_INITIAL_LOOKBACK_HOURS=24
COLLEAGUE_SLACK_EVENT_MAX_ATTEMPTS=3

# Native neuro-san periodic schedule. The default in the manifest is every 15
# minutes. Keep the interval longer than COLLEAGUE_MAX_RUN_SECONDS.
# COLLEAGUE_CRON_SCHEDULE=*/15 * * * *
# Fixed to match max_execution_seconds in the sample registry.
COLLEAGUE_MAX_RUN_SECONDS=600
COLLEAGUE_REPORT_INTERVAL_HOURS=24
COLLEAGUE_STALE_AFTER_DAYS=14
COLLEAGUE_MAX_PROJECT_ITEMS=500

# Durable local state. Mount this directory on persistent storage in production.
COLLEAGUE_STATE_PATH=.state/colleague.json
COLLEAGUE_AUDIT_PATH=.state/audit.jsonl

# Server and event bridge.
NEURO_SAN_BASE_URL=http://localhost:8080
NEURO_SAN_SERVER_HTTP_PORT=8080
AGENT_HTTP_SERVER_INSTANCES=1
# Never write teammate request text into Neuro SAN request logs.
AGENT_REQUEST_LOGGING_INPUT_SLICE=0
